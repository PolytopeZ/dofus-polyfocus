<ui:FluentWindow x:Class="DofusPolyfocus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DofusPolyfocus"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Polyfocus" Height="280" Width="240"
        Topmost="True" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual" Left="20" Top="20"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">
    <DockPanel Margin="6">
        <ui:TitleBar DockPanel.Dock="Top" Title="Polyfocus" Margin="-6,-6,-6,6" />
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11" Foreground="Gray" TextWrapping="Wrap">
            Ctrl+1..9 select · Ctrl+Tab / Ctrl+Shift+Tab rotate · click to switch
        </TextBlock>
        <ListBox x:Name="SlotsList" SelectionChanged="SlotsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <Grid Width="22" Height="22" Margin="0,0,8,0">
                            <Border Background="{Binding ClassBrush}" CornerRadius="10">
                                <TextBlock Text="{Binding ClassInitials}" FontSize="10" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Image Source="{Binding ClassIcon}" Stretch="Uniform" />
                        </Grid>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</ui:FluentWindow>
